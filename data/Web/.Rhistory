count(test) %>%
filter(n > 700) %>%
mutate(test = reorder(test, n)) %>%
ggplot() +
aes(test, n) +
geom_col() +
coord_flip()
test_descripteurs %>%
top_n(1000) %>%
ggplot(aes(x = reorder(test, n), y = n)) +
geom_col(fill = "skyblue", color = "black") +
labs(title = "Top 20 des termes dans le corpus",
x = "Termes",
y = "Occurrences") +
coord_flip()
