# Installer et charger les bibliothèques nécessaires
# install.packages("httr") # Assurez-vous que httr est installé
library(httr)
library(jsonlite)
# Faire la requête à l'API pour obtenir les informations sur les adresses
response <- GET("https://geo.api.gouv.fr/communes/91300/voies?fields=nom&format=json")
# Vérifier si la requête a réussi
if (http_status(response)$category == "Success") {
# Convertir la réponse en format JSON
data <- content(response, "text", encoding = "UTF-8")
json_data <- fromJSON(data)
# Filtrer les noms de voies qui contiennent "Avenue"
avenues_massy <- json_data[grepl("Avenue", json_data$nom), "nom"]
# Écrire les noms de voies dans un fichier CSV
write.csv(avenues_massy, "avenues_massy.csv", row.names = FALSE)
} else {
# Afficher un message d'erreur si la requête a échoué
print("La requête a échoué.")
}
View(response)
