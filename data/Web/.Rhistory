avenues <- data[grep("Avenue", data$nom), "nom"]
# Créer un dataframe
df <- data.frame(Avenues = avenues)
# Enregistrer le dataframe dans un fichier CSV
write.csv(df, "noms_avenues_massy.csv", row.names = FALSE)
print("Fichier CSV créé avec succès.")
} else {
# Afficher le statut de la réponse en cas d'erreur
print(paste("Erreur lors de la récupération des données. Statut de la réponse:", status_code(response)))
}
