library(tidyverse)
library(tidytext)
# Données textuelles ------------------------------------------------------
poeme1 <- "Tous les poteaux télégraphiques
Viennent là-bas le long du quai
Sur son sein notre République
A mis ce bouquet de muguet"
poeme1
poeme2 <- "La sottise, l'erreur, le péché, la lésine,
Occupent nos esprits et travaillent nos corps,
Et nous alimentons nos aimables remords,
Comme les mendiants nourrissent leur vermine."
poeme2
poemes_bruts <- tibble(n_poeme = 1:2,
texte_poeme = c(poeme1, poeme2))
poemes_bruts
# Tokénisation ------------------------------------------------------------
poemes_mots <- poemes_bruts %>%
unnest_tokens(output = mots_poeme,
input = texte_poeme)
poemes_mots
# Mots-vides --------------------------------------------------------------
library(tm)
stopwords("french") # mots vides du français
poemes_mots_pleins <- poemes_mots %>%
filter(!mots_poeme %in% stopwords("french"))
poemes_mots_pleins
# Racinisation et lemmatisation -------------------------------------------
library(SnowballC)
poemes_racines <- poemes_mots_pleins %>%
mutate(racines_mots = wordStem(mots_poeme, language = "french"))
poemes_racines
library(udpipe)
udpipe(poeme1, "french")
udpipe(poeme1, "french")$lemma
poemes_lemmes <- udpipe(split(poemes_mots$mots_poeme,
poemes_mots$n_poeme),
"french") %>%
select(doc_id, lemma) # choisissez les colonnes qui vous servent
poemes_lemmes
# Remplacement ------------------------------------------------------------
str_replace_all(poeme1, "e", "-")
str_replace_all(poeme1, "les", "") # éliminer toutes les occurrence du mot "les"
poemes_lemmes %>%
mutate(sans_l_erreur = str_replace_all(lemma, "l'erreur", "")) %>%
select(lemma, sans_l_erreur)
# Exercice : Corpus Jane Austen -------------------------------------------
# Créez un jeu de données appelé austen_clean
library(janeaustenr)
austen_livres_bruts <- austen_books() # les livres de Jane Austen
View(austen_livres_bruts)
# Occurrences -------------------------------------------------------------
# visualisation des occurrences dans l'entier corpus
