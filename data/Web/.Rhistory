count(mot) %>%
filter(n > 700) %>%
mutate(mot = reorder(mot, n)) %>%
ggplot() +
aes(mot, n) +
geom_col() +
coord_flip()
test_descripteurs %>%
count(test) %>%
filter(n > 1000) %>%
mutate(test = reorder(test, n)) %>%
ggplot() +
aes(test, n) +
geom_col() +
coord_flip()
View(austen_livres_bruts)
View(austen_livres_bruts)
